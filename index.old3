<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <title>Pozorantsi Song Base</title>
  <style>
    :root {
      --bg: #07111f;
      --panel: #0d1a2b;
      --border: #21324a;
      --text: #f4f7fb;
      --muted: #9ba9bb;
      --purple: #7c3cff;
      --purple2: #a778ff;
      --orange: #ff7a00;
      --green: #18c955;
      --yellow: #f2ad16;
      --blue: #1698e8;
      --red: #ff3333;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Inter, Segoe UI, Arial, sans-serif;
      background:
        radial-gradient(circle at 20% 0%, rgba(84, 58, 183, .2), transparent 32%),
        linear-gradient(135deg, #040910 0%, #081326 55%, #03070d 100%);
      color: var(--text);
      height: 100vh;
      overflow: hidden;
    }

    button, input, select, textarea { font-family: inherit; }

    .app {
      display: grid;
      grid-template-columns: 42px 1fr 42px;
      grid-template-rows: 72px 1fr 82px;
      height: 100vh;
      transition: .2s;
    }

    .app.left-open { grid-template-columns: 280px 1fr 42px; }
    .app.right-open { grid-template-columns: 42px 1fr 320px; }
    .app.left-open.right-open { grid-template-columns: 280px 1fr 320px; }

    header {
      grid-column: 1 / 4;
      display: grid;
      grid-template-columns: 280px 1fr 360px;
      align-items: center;
      border-bottom: 1px solid rgba(255,255,255,.08);
      background: rgba(5, 10, 18, .72);
      backdrop-filter: blur(16px);
      padding: 0 18px;
    }

    .brand-main {
      font-size: 34px;
      font-weight: 800;
      letter-spacing: -1.5px;
      line-height: 1;
    }
    .brand-main .orange { color: var(--orange); }
    .brand-sub {
      margin-left: 36px;
      margin-top: 8px;
      color: var(--purple2);
      letter-spacing: 4px;
      font-weight: 700;
      font-size: 13px;
    }

    .top-stats {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 18px;
      font-weight: 700;
    }
    .music-icon { color: var(--purple2); font-size: 24px; }

    .top-actions {
      display: flex;
      align-items: center;
      justify-content: flex-end;
      gap: 12px;
    }

    .top-btn, .icon-btn {
      border: 1px solid var(--border);
      background: rgba(13, 26, 43, .8);
      color: var(--text);
      border-radius: 10px;
      cursor: pointer;
      font-weight: 650;
    }
    .top-btn { padding: 10px 16px; }
    .icon-btn { width: 42px; height: 42px; font-size: 18px; }

    aside.left, aside.right {
      grid-row: 2 / 3;
      overflow: hidden;
      position: relative;
      background: rgba(6, 12, 22, .22);
    }

    aside.left { border-right: 1px solid rgba(255,255,255,.07); }
    aside.right { border-left: 1px solid rgba(255,255,255,.07); }

    .side-toggle {
      position: absolute;
      top: 12px;
      width: 30px;
      height: 44px;
      border: 1px solid var(--border);
      background: rgba(13, 26, 43, .94);
      color: var(--text);
      border-radius: 10px;
      cursor: pointer;
      z-index: 4;
      font-weight: 800;
    }
    aside.left .side-toggle { right: 6px; }
    aside.right .side-toggle { left: 6px; }

    .side-content {
      width: 280px;
      height: 100%;
      padding: 68px 10px 12px;
      overflow: auto;
      opacity: 0;
      pointer-events: none;
      transition: .15s;
    }

    .app.left-open .left .side-content,
    .app.right-open .right .side-content {
      opacity: 1;
      pointer-events: auto;
    }

    aside.right .side-content { width: 320px; padding: 68px 18px 14px; }

    main {
      grid-row: 2 / 3;
      padding: 0 18px 12px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .sidebar-card, .song-row, .search-wrap, .filters-row, .player {
      background: rgba(13, 26, 43, .72);
      border: 1px solid rgba(255,255,255,.08);
      box-shadow: 0 18px 40px rgba(0,0,0,.18);
    }

    .sidebar-card {
      border-radius: 12px;
      margin-bottom: 12px;
      overflow: hidden;
    }
    .sidebar-title {
      padding: 14px 16px;
      font-weight: 800;
      font-size: 14px;
      border-bottom: 1px solid rgba(255,255,255,.07);
      display: flex;
      gap: 8px;
    }
    .filter-group {
      padding: 10px 10px 12px;
      border-bottom: 1px solid rgba(255,255,255,.05);
    }
    .filter-label {
      color: var(--muted);
      font-size: 11px;
      text-transform: uppercase;
      font-weight: 800;
      margin: 4px 4px 8px;
    }
    .filter-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 7px 8px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }
    .filter-item:hover, .filter-item.active {
      background: linear-gradient(90deg, rgba(124,60,255,.35), rgba(124,60,255,.08));
    }
    .filter-name { display: flex; align-items: center; gap: 9px; }
    .dot { width: 13px; height: 13px; border-radius: 50%; display: inline-block; }
    .count {
      background: rgba(255,255,255,.07);
      padding: 2px 8px;
      border-radius: 999px;
      min-width: 34px;
      text-align: center;
    }

    .recent-item {
      display: grid;
      grid-template-columns: 24px 1fr;
      gap: 8px;
      padding: 6px 10px;
      font-size: 13px;
    }
    .recent-title { font-weight: 700; }
    .recent-artist { color: var(--muted); font-size: 11px; margin-top: 2px; }

    .search-wrap {
      margin-top: 10px;
      border-radius: 16px;
      padding: 16px;
      display: grid;
      grid-template-columns: 1fr 210px;
      gap: 14px;
      flex-shrink: 0;
    }
    .search-box { position: relative; }
    .search-box span {
      position: absolute;
      left: 18px;
      top: 50%;
      transform: translateY(-50%);
      font-size: 24px;
      color: var(--muted);
    }
    .search-box input {
      width: 100%;
      height: 56px;
      padding: 0 20px 0 56px;
      border: 1px solid var(--border);
      background: rgba(6, 13, 24, .92);
      color: var(--text);
      border-radius: 12px;
      font-size: 18px;
      outline: none;
    }
    .add-btn {
      border: 0;
      border-radius: 12px;
      background: linear-gradient(135deg, var(--purple), #5516d9);
      color: white;
      font-size: 18px;
      font-weight: 800;
      cursor: pointer;
    }

    .letters {
      display: flex;
      gap: 8px;
      padding: 12px 0;
      overflow-x: auto;
      flex-shrink: 0;
    }
    .letter {
      min-width: 34px;
      height: 34px;
      border: 1px solid rgba(255,255,255,.07);
      background: rgba(13, 26, 43, .78);
      color: var(--text);
      border-radius: 8px;
      cursor: pointer;
      font-weight: 700;
    }
    .letter.active { background: linear-gradient(135deg, var(--purple), #5516d9); }

    .filters-row {
      border-radius: 12px;
      padding: 10px;
      display: flex;
      gap: 10px;
      align-items: center;
      margin-bottom: 10px;
      overflow-x: auto;
      flex-shrink: 0;
    }
    .filter-select {
      height: 40px;
      min-width: 122px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: rgba(6, 13, 24, .92);
      color: var(--text);
      padding: 0 12px;
      outline: none;
    }
    .clear {
      margin-left: auto;
      white-space: nowrap;
      color: var(--purple2);
      background: transparent;
      border: 0;
      cursor: pointer;
      font-weight: 700;
    }

    .songs {
      overflow: auto;
      flex: 1;
      padding-right: 4px;
    }

    .song-row {
      display: grid;
      grid-template-columns: 58px 1.55fr 75px 105px 90px 86px 116px 78px;
      align-items: center;
      gap: 8px;
      min-height: 74px;
      border-radius: 12px;
      padding: 8px 10px;
      margin-bottom: 7px;
      cursor: pointer;
      transition: .15s;
    }
    .song-row:hover, .song-row.active {
      border-color: rgba(124,60,255,.75);
      background: rgba(19, 35, 58, .92);
    }
    .play {
      width: 46px;
      height: 46px;
      border-radius: 50%;
      border: 1px solid rgba(167,120,255,.7);
      color: #caaeff;
      background: transparent;
      font-size: 20px;
      cursor: pointer;
    }
    .title { font-size: 18px; font-weight: 800; margin-bottom: 4px; }
    .artist { color: var(--purple2); font-weight: 650; font-size: 14px; }
    .metric-main { font-size: 18px; font-weight: 800; text-align: center; }
    .metric-sub { color: var(--muted); font-size: 11px; text-align: center; margin-top: 3px; }
    .vocal, .status-cell { text-align: center; font-size: 14px; }
    .status-pill {
      display: inline-block;
      padding: 5px 11px;
      border-radius: 999px;
      font-weight: 800;
      font-size: 12px;
    }
    .green { background: rgba(24,201,85,.15); color: #53f383; }
    .yellow { background: rgba(242,173,22,.16); color: #ffc84d; }
    .blue { background: rgba(22,152,232,.16); color: #56c3ff; }
    .red { background: rgba(255,51,51,.14); color: #ff7777; }
    .thumb {
      width: 104px;
      height: 58px;
      border-radius: 8px;
      object-fit: cover;
      border: 1px solid rgba(255,255,255,.12);
    }
    .more {
      background: transparent;
      color: var(--muted);
      border: 0;
      font-size: 22px;
      cursor: pointer;
    }

    .details-title {
      display: flex;
      justify-content: space-between;
      align-items: start;
      margin-bottom: 2px;
    }
    .details-title h2 { margin: 0; font-size: 23px; }
    .close {
      background: transparent;
      color: var(--muted);
      border: 0;
      font-size: 28px;
      cursor: pointer;
    }
    .details-artist {
      color: var(--purple2);
      font-weight: 700;
      margin-bottom: 20px;
    }
    .tabs {
      display: flex;
      border-bottom: 1px solid rgba(255,255,255,.09);
      margin-bottom: 16px;
    }
    .tab {
      flex: 1;
      text-align: center;
      padding: 10px 0;
      color: var(--muted);
      font-weight: 700;
      font-size: 13px;
      border-bottom: 2px solid transparent;
    }
    .tab.active {
      color: var(--purple2);
      border-bottom-color: var(--purple);
    }
    .detail-line {
      display: grid;
      grid-template-columns: 30px 1fr auto;
      gap: 8px;
      align-items: center;
      margin-bottom: 18px;
      font-size: 14px;
    }
    .detail-label { color: var(--muted); }
    .detail-value { font-weight: 700; }
    .detail-actions { margin-top: 24px; display: grid; gap: 10px; }
    .big-action {
      height: 46px;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: rgba(13, 26, 43, .7);
      color: var(--text);
      font-size: 16px;
      font-weight: 800;
      cursor: pointer;
    }
    .big-action.primary { border: 0; background: linear-gradient(135deg, var(--purple), #5516d9); }
    .big-action.danger { color: #ff4c4c; border-color: rgba(255,51,51,.7); background: transparent; }

    .player {
      grid-column: 1 / 4;
      display: grid;
      grid-template-columns: 280px 1fr 360px;
      align-items: center;
      border-left: 0;
      border-right: 0;
      border-bottom: 0;
      border-radius: 14px 14px 0 0;
      padding: 8px 18px;
      background: rgba(7, 17, 31, .96);
      backdrop-filter: blur(14px);
    }
    .now { display: flex; gap: 14px; align-items: center; }
    .now img { width: 86px; height: 54px; object-fit: cover; border-radius: 8px; }
    .now-title { font-weight: 800; font-size: 17px; }
    .now-artist { color: var(--purple2); margin-top: 4px; }
    .controls { display: flex; align-items: center; justify-content: center; gap: 14px; flex-wrap: wrap; }
    .control-btn {
      border: 1px solid var(--border);
      background: rgba(13, 26, 43, .85);
      color: var(--text);
      height: 42px;
      min-width: 54px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 800;
    }
    .main-play {
      width: 54px;
      height: 54px;
      border-radius: 50%;
      border-color: var(--purple);
      color: white;
      background: rgba(124,60,255,.18);
      font-size: 22px;
    }
    .progress {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 6px;
      color: var(--muted);
      font-size: 12px;
      max-width: 560px;
      margin-inline: auto;
    }
    .bar { flex: 1; height: 5px; background: #1b2a3f; border-radius: 999px; overflow: hidden; cursor:pointer; }
    .bar span { display: block; width: 0%; height: 100%; background: var(--purple); }
    .volume { display: flex; justify-content: flex-end; align-items: center; gap: 14px; }

    #miniVideo {
      position: fixed;
      inset: 0;
      background: rgba(1,4,10,.78);
      backdrop-filter: blur(10px);
      z-index: 60;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    #miniVideo.show { display:flex; }
    .yt-modal-box {
      width: min(720px, 94vw);
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 16px;
      box-shadow: 0 30px 90px rgba(0,0,0,.5);
    }
    .yt-modal-head {
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      margin-bottom:12px;
    }
    .yt-modal-title {
      font-weight:800;
      font-size:18px;
    }
    .yt-modal-sub {
      color:var(--purple2);
      font-size:13px;
      margin-top:3px;
    }
    .yt-close {
      border:1px solid var(--border);
      background:rgba(13,26,43,.85);
      color:var(--text);
      border-radius:10px;
      padding:9px 12px;
      cursor:pointer;
      font-weight:800;
    }
    #youtubePlayer {
      width:100%;
      aspect-ratio:16/9;
      background:#000;
      border-radius:12px;
      overflow:hidden;
    }

    .modal {
      position: fixed;
      inset: 0;
      background: rgba(1,4,10,.75);
      backdrop-filter: blur(10px);
      display: none;
      align-items: center;
      justify-content: center;
      z-index: 50;
    }
    .modal.open { display: flex; }
    .modal-box {
      width: 520px;
      max-width: calc(100vw - 28px);
      max-height: 90vh;
      overflow: auto;
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 18px;
      box-shadow: 0 30px 80px rgba(0,0,0,.45);
    }
    .modal-box h2 { margin: 0 0 12px; }
    .modal-box label {
      display: block;
      color: var(--muted);
      margin-bottom: 7px;
      font-size: 13px;
      font-weight: 700;
    }
    .modal-box input, .modal-box select, .modal-box textarea {
      width: 100%;
      border: 1px solid var(--border);
      background: rgba(4,10,18,.92);
      color: var(--text);
      border-radius: 10px;
      padding: 9px 10px;
      outline: none;
      margin-bottom: 8px;
      font-size: 14px;
    }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px 12px; }
    .modal-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 10px; }
    .vocal-manage {
      padding: 10px;
      border-top: 1px solid rgba(255,255,255,.06);
    }
    .vocal-add {
      display: grid;
      grid-template-columns: 1fr 42px;
      gap: 8px;
      margin-bottom: 8px;
    }
    .vocal-add input {
      min-width: 0;
      border: 1px solid var(--border);
      background: rgba(4,10,18,.92);
      color: var(--text);
      border-radius: 8px;
      padding: 9px;
      outline: none;
    }
    .vocal-add button {
      border: 0;
      border-radius: 8px;
      background: linear-gradient(135deg, var(--purple), #5516d9);
      color: white;
      cursor: pointer;
      font-weight: 900;
    }
    .vocal-row {
      display:flex;
      align-items:center;
      justify-content:space-between;
      padding: 6px 4px;
      color: var(--text);
      font-size: 13px;
    }
    .vocal-row button {
      border:0;
      background:transparent;
      color:#ff7777;
      cursor:pointer;
      font-weight:900;
    }

    @media (max-width: 900px) {
      body { overflow:auto; height:auto; }
      .app { display:block; height:auto; }
      header { display:block; padding:14px; }
      aside.left, aside.right { display:none; }
      main { padding:12px; overflow:visible; }
      .search-wrap { grid-template-columns:1fr; }
      .song-row {
        grid-template-columns: 54px 1fr 74px;
        min-height: 78px;
      }
      .song-row .metric:nth-of-type(n+2), .vocal, .status-cell, .thumb, .more { display:none; }
      .player {
        position: sticky;
        bottom: 0;
        grid-template-columns: 1fr;
        gap: 8px;
      }
      .volume { display:none; }
    }
  </style>
</head>
<body>
<div class="app" id="app">
  <header>
    <div class="brand">
      <div class="brand-main">pozorants<span class="orange">i</span></div>
      <div class="brand-sub">SONG BASE</div>
    </div>
    <div class="top-stats"><span class="music-icon">♫</span><span id="totalCount">0 utworów</span></div>
    <div class="top-actions">
      <button class="top-btn" onclick="exportData()">⇧ Eksport</button>
      <label class="top-btn">⇩ Import <input id="importFile" type="file" accept=".json" style="display:none" onchange="importData(event)"></label>
      <button class="top-btn" onclick="openAiSettings()">AI BPM/tonacja</button>
      <button class="icon-btn" onclick="toggleLeft()">☰</button>
      <button class="icon-btn" onclick="toggleRight()">ⓘ</button>
    </div>
  </header>

  <aside class="left">
    <button class="side-toggle" onclick="toggleLeft()" id="leftToggle">›</button>
    <div class="side-content">
      <div class="sidebar-card">
        <div class="sidebar-title">▽ FILTRY</div>
        <div class="filter-group">
          <div class="filter-label">STATUS</div>
          <div id="statusFilters"></div>
        </div>
        <div class="filter-group">
          <div class="filter-label">WOKAL</div>
          <div id="vocalFilters"></div>
        </div>
        <div class="vocal-manage">
          <div class="filter-label">EDYCJA WOKALISTÓW</div>
          <div class="vocal-add">
            <input id="newVocalInput" placeholder="Dodaj osobę..." />
            <button onclick="addVocalist()">+</button>
          </div>
          <div id="vocalManager"></div>
        </div>
      </div>

      <div class="sidebar-card">
        <div class="sidebar-title">◷ OSTATNIO ODTWARZANE</div>
        <div id="recentList"></div>
        <div style="padding: 10px;">
          <button class="top-btn" style="width:100%" onclick="clearRecent()">Wyczyść listę</button>
        </div>
      </div>
    </div>
  </aside>

  <main>
    <section class="search-wrap">
      <div class="search-box">
        <span>⌕</span>
        <input id="searchInput" placeholder="Szukaj wykonawcy lub utworu..." oninput="render()" />
      </div>
      <button class="add-btn" onclick="openModal()">＋ Dodaj utwór</button>
    </section>

    <section class="letters" id="letters"></section>

    <section class="filters-row">
      <select class="filter-select" id="keyFilter" onchange="render()"><option value="">Tonacja</option></select>
      <select class="filter-select" id="bpmFrom" onchange="render()">
        <option value="">BPM od</option><option>60</option><option>80</option><option>100</option><option>120</option>
      </select>
      <select class="filter-select" id="bpmTo" onchange="render()">
        <option value="">BPM do</option><option>90</option><option>110</option><option>130</option><option>160</option>
      </select>
      <select class="filter-select" id="vocalSelect" onchange="render()"><option value="">Wokal</option></select>
      <select class="filter-select" id="statusSelect" onchange="render()"><option value="">Status</option></select>
      <select class="filter-select" id="dateSort" onchange="render()">
        <option value="">Dodano</option><option value="new">Najnowsze</option><option value="old">Najstarsze</option>
      </select>
      <button class="clear" onclick="clearFilters()">× Wyczyść filtry</button>
    </section>

    <section class="songs" id="songsList"></section>
  </main>

  <aside class="right">
    <button class="side-toggle" onclick="toggleRight()" id="rightToggle">‹</button>
    <div class="side-content" id="details"></div>
  </aside>

  <section class="player">
    <div class="now">
      <img id="nowThumb" src="https://img.youtube.com/vi/fNFzfwLM72c/hqdefault.jpg" alt="">
      <div>
        <div class="now-title" id="nowTitle">Stayin’ Alive</div>
        <div class="now-artist" id="nowArtist">Bee Gees</div>
      </div>
    </div>
    <div>
      <div class="controls">
        <button class="control-btn" onclick="showYoutubeForSelected()">📺 YouTube</button>
        <button class="control-btn" onclick="skip(-20)">-20s</button>
        <button class="control-btn" onclick="skip(-10)">-10s</button>
        <button class="control-btn main-play" id="mainPlayBtn" onclick="togglePlay()">▶</button>
        <button class="control-btn" onclick="skip(10)">+10s</button>
        <button class="control-btn" onclick="skip(20)">+20s</button>
      </div>
      <div class="progress">
        <span id="curTime">0:00</span><div class="bar" onclick="seekByClick(event)"><span id="progressFill"></span></div><span id="durTime">0:00</span>
      </div>
    </div>
    <div class="volume">🔊 <input id="volumeSlider" type="range" value="70" min="0" max="100" oninput="setVolume(this.value)"></div>
  </section>
</div>

<div id="miniVideo">
  <div class="yt-modal-box">
    <div class="yt-modal-head">
      <div>
        <div class="yt-modal-title" id="ytModalTitle">YouTube</div>
        <div class="yt-modal-sub" id="ytModalArtist">Pozorantsi Song Base</div>
      </div>
      <button class="yt-close" onclick="toggleMiniVideo(false)">Zamknij</button>
    </div>
    <div style="position:relative;">
      <div id="youtubePlayer"></div>
      <div id="ytFallback" style="display:none;position:absolute;inset:0;background:rgba(0,0,0,.86);color:white;padding:18px;text-align:center;font-size:14px;align-items:center;justify-content:center;flex-direction:column;gap:12px;border-radius:12px;">
        <div>YouTube zablokował osadzony player w tym podglądzie.</div>
        <a id="ytFallbackLink" target="_blank" style="color:#a778ff;font-weight:800;">Otwórz w YouTube</a>
      </div>
    </div>
  </div>
</div>


<div class="modal" id="aiModal">
  <div class="modal-box">
    <h2>AI BPM / tonacja</h2>
    <p style="color:var(--muted);line-height:1.5;margin-top:0;font-size:14px;">
      Wklej swój klucz Google Gemini API. Klucz zostanie zapisany tylko w tej przeglądarce.
      Po wklejeniu linku YouTube program spróbuje sam rozpoznać wykonawcę, tytuł, BPM i tonację.
    </p>
    <label>Gemini API Key</label>
    <input id="geminiKeyInput" type="password" placeholder="AIza..." />
    <div class="modal-actions">
      <button class="top-btn" onclick="closeAiSettings()">Anuluj</button>
      <button class="add-btn" style="padding: 0 20px;" onclick="saveAiSettings()">Zapisz</button>
    </div>
  </div>
</div>

<div class="modal" id="songModal">
  <div class="modal-box">
    <h2 id="modalTitle">Dodaj utwór</h2>
    <label>Link YouTube</label>
    <input id="ytUrl" placeholder="Wklej link z YouTube..." />
    <div class="modal-actions" style="justify-content:flex-start;margin-top:0;margin-bottom:12px;">
      <button class="top-btn" onclick="analyzeLink()">Analizuj link + AI</button>
    </div>

    <div class="form-grid">
      <div><label>Wykonawca</label><input id="artistInput" /></div>
      <div><label>Tytuł</label><input id="titleInput" /></div>
      <div><label>BPM</label><input id="bpmInput" type="number" /></div>
      <div><label>Tonacja oryginalna</label><input id="keyInput" placeholder="np. Fm" /></div>
      <div><label>Tonacja Pozorantsi</label><input id="bandKeyInput" placeholder="np. Em" /></div>
      <div>
        <label>Wokal</label>
        <select id="vocalInput">
          <option>Lisa</option><option>Ewa</option><option>Zuzia</option><option>Marek</option><option>Duet</option><option>Instrumental</option>
        </select>
      </div>
    </div>

    <label>Status</label>
    <select id="statusInput">
      <option>Nowe</option><option>Ćwiczymy</option><option>Gramy</option><option>Archiwum</option>
    </select>

    <label>Notatki</label>
    <textarea id="notesInput" rows="3"></textarea>

    <div class="modal-actions">
      <button class="top-btn" onclick="closeModal()">Anuluj</button>
      <button class="add-btn" style="padding: 0 20px;" onclick="saveSong()">Zapisz</button>
    </div>
  </div>
</div>

<script>
let ytReady = false;
let player = null;
let progressTimer = null;
let currentSong = null;

window.onYouTubeIframeAPIReady = function() {
  ytReady = true;
};

const tag = document.createElement('script');
tag.src = "https://www.youtube.com/iframe_api";
document.head.appendChild(tag);

const KEYS = ['C','Cm','D','Dm','Eb','Em','E','F','Fm','F#','G','Gm','Ab','Am','A','Bb','Bm','B'];
let vocalNames = JSON.parse(localStorage.getItem('pozorantsi_vocalists') || 'null') || ['Lisa','Ewa','Zuzia','Marek','Duet','Instrumental'];
function getVocalMenu(){ return ['Wszyscy', ...vocalNames]; }
const STATUSES = ['Wszystkie','Gramy','Ćwiczymy','Nowe','Archiwum'];

let songs = JSON.parse(localStorage.getItem('pozorantsi_v3_songs') || 'null') || [
  {id:'1', artist:'Bee Gees', title:'Stayin’ Alive', bpm:104, key:'Fm', bandKey:'Em', vocal:'Lisa', status:'Gramy', date:'2026-06-17', yt:'https://www.youtube.com/watch?v=fNFzfwLM72c', ytId:'fNFzfwLM72c', notes:'Wejście perkusji po 4 taktach. Zwrotka od gitary.'},
  {id:'2', artist:'Bee Gees', title:'How Deep Is Your Love', bpm:82, key:'Eb', bandKey:'D', vocal:'Marek', status:'Gramy', date:'2026-06-12', yt:'https://www.youtube.com/watch?v=XpqqjU7u5Yc', ytId:'XpqqjU7u5Yc', notes:''},
  {id:'3', artist:'Beyoncé', title:'Halo', bpm:80, key:'A', bandKey:'G', vocal:'Ewa', status:'Ćwiczymy', date:'2026-06-11', yt:'https://www.youtube.com/watch?v=bnVUHWCynig', ytId:'bnVUHWCynig', notes:''},
  {id:'4', artist:'Tina Turner', title:'Simply The Best', bpm:116, key:'F', bandKey:'D', vocal:'Lisa', status:'Gramy', date:'2026-06-10', yt:'https://www.youtube.com/watch?v=GC5E8ie2pdM', ytId:'GC5E8ie2pdM', notes:''},
  {id:'5', artist:'Lady Gaga / Bradley Cooper', title:'Shallow', bpm:96, key:'G', bandKey:'F', vocal:'Duet', status:'Gramy', date:'2026-06-09', yt:'https://www.youtube.com/watch?v=bo_efYhYU2A', ytId:'bo_efYhYU2A', notes:''},
  {id:'6', artist:'Bon Jovi', title:"It’s My Life", bpm:120, key:'Am', bandKey:'Gm', vocal:'Marek', status:'Gramy', date:'2026-06-08', yt:'https://www.youtube.com/watch?v=vx2u5uUu3DE', ytId:'vx2u5uUu3DE', notes:''},
  {id:'7', artist:'Gloria Gaynor', title:'I Will Survive', bpm:128, key:'Fm', bandKey:'Em', vocal:'Zuzia', status:'Ćwiczymy', date:'2026-06-07', yt:'https://www.youtube.com/watch?v=6dYWe1c3OyU', ytId:'6dYWe1c3OyU', notes:''},
  {id:'8', artist:'Queen', title:'Don’t Stop Me Now', bpm:156, key:'F', bandKey:'E', vocal:'Marek', status:'Nowe', date:'2026-06-06', yt:'https://www.youtube.com/watch?v=HgzGwKwLmgM', ytId:'HgzGwKwLmgM', notes:''},
  {id:'9', artist:'ABBA', title:'Dancing Queen', bpm:101, key:'A', bandKey:'G', vocal:'Zuzia', status:'Gramy', date:'2026-06-05', yt:'https://www.youtube.com/watch?v=xFrGuyw1V8s', ytId:'xFrGuyw1V8s', notes:''}
];

let selectedId = songs[0]?.id;
let activeLetter = '';
let activeStatus = 'Wszystkie';
let activeVocal = 'Wszyscy';
let editingId = null;
let recent = JSON.parse(localStorage.getItem('pozorantsi_v3_recent') || '[]');

function toggleLeft(){
  app.classList.toggle('left-open');
  leftToggle.textContent = app.classList.contains('left-open') ? '‹' : '›';
}
function toggleRight(){
  app.classList.toggle('right-open');
  rightToggle.textContent = app.classList.contains('right-open') ? '›' : '‹';
}

function saveAll(){
  localStorage.setItem('pozorantsi_v3_songs', JSON.stringify(songs));
  localStorage.setItem('pozorantsi_v3_recent', JSON.stringify(recent));
  localStorage.setItem('pozorantsi_vocalists', JSON.stringify(vocalNames));
}

function youtubeId(url){
  try {
    const u = new URL(url);
    if (u.hostname.includes('youtu.be')) return u.pathname.slice(1).split(/[?&]/)[0];
    if (u.searchParams.get('v')) return u.searchParams.get('v');
    const parts = u.pathname.split('/');
    return parts[parts.length-1] || '';
  } catch { return ''; }
}

function thumb(s){ return `https://img.youtube.com/vi/${s.ytId}/mqdefault.jpg`; }

function refreshVocalSelects(){
  if(window.vocalSelect) {
    vocalSelect.innerHTML = '<option value="">Wokal</option>' + vocalNames.map(v => `<option value="${escAttr(v)}">${esc(v)}</option>`).join('');
  }
  if(window.vocalInput) {
    const current = vocalInput.value || vocalNames[0] || '';
    vocalInput.innerHTML = vocalNames.map(v => `<option value="${escAttr(v)}">${esc(v)}</option>`).join('');
    if(vocalNames.includes(current)) vocalInput.value = current;
  }
}

function renderVocalManager(){
  if(!window.vocalManager) return;
  vocalManager.innerHTML = vocalNames.map(v => `
    <div class="vocal-row">
      <span>🎙 ${esc(v)}</span>
      <button onclick="removeVocalist('${escAttr(v)}')" title="Usuń">×</button>
    </div>
  `).join('');
}

function addVocalist(){
  const name = (newVocalInput.value || '').trim();
  if(!name) return;
  if(!vocalNames.includes(name)) vocalNames.push(name);
  newVocalInput.value = '';
  localStorage.setItem('pozorantsi_vocalists', JSON.stringify(vocalNames));
  refreshVocalSelects();
  renderSidebar();
}

function removeVocalist(name){
  if(songs.some(s => s.vocal === name)) {
    if(!confirm('Ten wokalista jest przypisany do utworów. Usunąć go z listy filtrów mimo to?')) return;
  }
  vocalNames = vocalNames.filter(v => v !== name);
  if(activeVocal === name) activeVocal = 'Wszyscy';
  localStorage.setItem('pozorantsi_vocalists', JSON.stringify(vocalNames));
  refreshVocalSelects();
  renderSidebar();
  render();
}

function openAiSettings(){
  geminiKeyInput.value = localStorage.getItem('pozorantsi_gemini_key') || '';
  aiModal.classList.add('open');
}
function closeAiSettings(){ aiModal.classList.remove('open'); }
function saveAiSettings(){
  localStorage.setItem('pozorantsi_gemini_key', geminiKeyInput.value.trim());
  closeAiSettings();
  alert('Zapisano ustawienia AI.');
}

function init(){
  KEYS.forEach(k => keyFilter.innerHTML += `<option value="${k}">${k}</option>`);
  refreshVocalSelects();
  ['Gramy','Ćwiczymy','Nowe','Archiwum'].forEach(s => statusSelect.innerHTML += `<option value="${s}">${s}</option>`);
  renderLetters();
  renderSidebar();
  render();
  renderDetails();
}

function renderLetters(){
  const letters = ['A','B','C','D','E','F','G','H','I','J','K','L','M','N','O','P','R','S','T','U','W','Z','#'];
  document.getElementById('letters').innerHTML = letters.map(l => `<button class="letter ${activeLetter===l?'active':''}" onclick="setLetter('${l}')">${l}</button>`).join('');
}

function setLetter(l){
  activeLetter = activeLetter === l ? '' : l;
  renderLetters();
  render();
}

function renderSidebar(){
  statusFilters.innerHTML = STATUSES.map(s => {
    const count = s === 'Wszystkie' ? songs.length : songs.filter(x => x.status === s).length;
    const color = s === 'Gramy' ? 'var(--green)' : s === 'Ćwiczymy' ? 'var(--yellow)' : s === 'Nowe' ? 'var(--blue)' : s === 'Archiwum' ? 'var(--red)' : 'var(--purple)';
    return `<div class="filter-item ${activeStatus===s?'active':''}" onclick="setStatus('${s}')"><span class="filter-name"><span class="dot" style="background:${color}"></span>${s}</span><span class="count">${count}</span></div>`;
  }).join('');

  vocalFilters.innerHTML = getVocalMenu().map(v => {
    const count = v === 'Wszyscy' ? songs.length : songs.filter(x => x.vocal === v).length;
    return `<div class="filter-item ${activeVocal===v?'active':''}" onclick="setVocal('${escAttr(v)}')"><span class="filter-name">♬ ${esc(v)}</span><span class="count">${count}</span></div>`;
  }).join('');

  renderVocalManager();
  renderRecent();
  totalCount.textContent = songs.length + ' utworów';
}

function setStatus(s){ activeStatus=s; renderSidebar(); render(); }
function setVocal(v){ activeVocal=v; renderSidebar(); render(); }

function filtered(){
  const q = searchInput.value.toLowerCase().trim();
  const key = keyFilter.value;
  const vf = vocalSelect.value;
  const sf = statusSelect.value;
  const bpmMin = Number(bpmFrom.value || 0);
  const bpmMax = Number(bpmTo.value || 999);
  let list = [...songs];

  if(q) list = list.filter(s => (s.artist+' '+s.title+' '+s.key+' '+s.bandKey).toLowerCase().includes(q));
  if(activeLetter) list = list.filter(s => activeLetter==='#' ? !/^[a-ząćęłńóśźż]/i.test(s.artist) : s.artist.toUpperCase().startsWith(activeLetter));
  if(activeStatus !== 'Wszystkie') list = list.filter(s => s.status === activeStatus);
  if(activeVocal !== 'Wszyscy') list = list.filter(s => s.vocal === activeVocal);
  if(key) list = list.filter(s => s.key === key || s.bandKey === key);
  if(vf) list = list.filter(s => s.vocal === vf);
  if(sf) list = list.filter(s => s.status === sf);
  list = list.filter(s => Number(s.bpm || 0) >= bpmMin && Number(s.bpm || 0) <= bpmMax);

  if(dateSort.value === 'new') list.sort((a,b) => b.date.localeCompare(a.date));
  else if(dateSort.value === 'old') list.sort((a,b) => a.date.localeCompare(b.date));
  else list.sort((a,b) => (a.artist+a.title).localeCompare(b.artist+b.title, 'pl'));

  return list;
}

function render(){
  const list = filtered();
  songsList.innerHTML = list.map(s => {
    const statusClass = s.status === 'Gramy' ? 'green' : s.status === 'Ćwiczymy' ? 'yellow' : s.status === 'Nowe' ? 'blue' : 'red';
    return `<div class="song-row ${selectedId===s.id?'active':''}" onclick="selectSong('${s.id}')">
      <button class="play" onclick="event.stopPropagation(); playSong('${s.id}')">▶</button>
      <div><div class="title">${esc(s.title)}</div><div class="artist">${esc(s.artist)}</div></div>
      <div class="metric"><div class="metric-main">${s.bpm}</div><div class="metric-sub">BPM</div></div>
      <div class="metric"><div class="metric-main">${esc(s.key)} → ${esc(s.bandKey)}</div><div class="metric-sub">Tonacja</div></div>
      <div class="vocal">♬ ${esc(s.vocal)}<div class="metric-sub">Wokal</div></div>
      <div class="status-cell"><span class="status-pill ${statusClass}">${s.status}</span></div>
      <img class="thumb" src="${thumb(s)}" onerror="this.style.display='none'">
      <div style="display:flex;gap:6px;justify-content:flex-end;">
        <button class="more" title="Edytuj" onclick="event.stopPropagation(); openEdit('${s.id}')">✎</button>
        <button class="more" title="Usuń" style="color:#ff7777" onclick="event.stopPropagation(); deleteSong('${s.id}')">×</button>
      </div>
    </div>`;
  }).join('') || `<div style="padding:40px;text-align:center;color:var(--muted)">Brak utworów dla wybranych filtrów.</div>`;
}

function selectSong(id){
  selectedId = id;
  render();
  renderDetails();
}

function renderDetails(){
  const s = songs.find(x => x.id === selectedId) || songs[0];
  if(!s) return;
  details.innerHTML = `
    <div class="details-title"><h2>${esc(s.title)}</h2><button class="close" onclick="toggleRight()">×</button></div>
    <div class="details-artist">${esc(s.artist)}</div>
    <div class="tabs"><div class="tab active">INFO</div><div class="tab">NOTATKI</div></div>
    ${line('◷','BPM', s.bpm)}
    ${line('♬','Tonacja oryginalna', s.key)}
    ${line('♬','Tonacja Pozorantsi', s.bandKey)}
    ${line('🎙','Wokal', s.vocal)}
    ${line('●','Status', s.status)}
    ${line('▣','Data dodania', formatDate(s.date))}
    ${line('▻','YouTube', '<a style="color:var(--purple2)" target="_blank" href="'+s.yt+'">Otwórz w YouTube ↗</a>')}
    <div style="margin-top:20px;color:var(--muted);font-weight:700;">Notatki</div>
    <div style="margin-top:10px;line-height:1.6;">${esc(s.notes || 'Brak notatek.')}</div>
    <div class="detail-actions">
      <button class="big-action primary" onclick="playSong('${s.id}')">▶ Odtwórz</button>
      <button class="big-action" onclick="showYoutube('${s.id}')">📺 Pokaż YouTube</button>
      <button class="big-action" onclick="openEdit('${s.id}')">✎ Edytuj</button>
      <button class="big-action danger" onclick="deleteSong('${s.id}')">🗑 Usuń utwór</button>
    </div>
  `;
}

function line(icon,label,value){
  return `<div class="detail-line"><div>${icon}</div><div class="detail-label">${label}</div><div class="detail-value">${value}</div></div>`;
}

function playSong(id){
  const s = songs.find(x => x.id === id);
  if(!s) return;

  selectedId = id;
  currentSong = s;
  ytModalTitle.textContent = s.title;
  ytModalArtist.textContent = s.artist;
  nowThumb.src = thumb(s);
  nowTitle.textContent = s.title;
  nowArtist.textContent = s.artist;
  recent = [id, ...recent.filter(x => x !== id)].slice(0,5);
  saveAll();
  render();
  renderDetails();
  renderSidebar();

  ytFallback.style.display = 'none';
  ytFallbackLink.href = s.yt || ('https://www.youtube.com/watch?v=' + s.ytId);

  const origin = (location.protocol === 'http:' || location.protocol === 'https:') ? location.origin : '';
  const playerVars = {
    autoplay: 1,
    controls: 1,
    rel: 0,
    modestbranding: 1,
    playsinline: 1,
    enablejsapi: 1
  };
  if(origin) playerVars.origin = origin;

  const startPlayer = () => {
    try {
      if(player && typeof player.loadVideoById === 'function') {
        player.loadVideoById(s.ytId);
        setTimeout(() => player.playVideo && player.playVideo(), 250);
      } else {
        document.getElementById('youtubePlayer').innerHTML = '';
        player = new YT.Player('youtubePlayer', {
          width: '100%',
          height: '100%',
          videoId: s.ytId,
          playerVars,
          events: {
            onReady: ev => {
              ev.target.setVolume(Number(volumeSlider.value || 70));
              ev.target.playVideo();
              startProgress();
            },
            onStateChange: ev => {
              if(ev.data === YT.PlayerState.PLAYING) {
                mainPlayBtn.textContent = '⏸';
                startProgress();
              }
              if(ev.data === YT.PlayerState.PAUSED || ev.data === YT.PlayerState.ENDED) {
                mainPlayBtn.textContent = '▶';
              }
            },
            onError: ev => showYoutubeFallback(ev.data)
          }
        });
      }
    } catch(e) {
      showYoutubeFallback('API');
    }
  };

  if(window.YT && YT.Player) startPlayer();
  else {
    setTimeout(() => {
      if(window.YT && YT.Player) startPlayer();
      else showYoutubeFallback('API');
    }, 900);
  }
}

function showYoutubeFallback(code){
  ytFallback.style.display = 'flex';
  mainPlayBtn.textContent = '▶';
  console.warn('YouTube player error:', code);
}

function togglePlay(){
  if(!player) {
    if(selectedId) playSong(selectedId);
    return;
  }
  const state = player.getPlayerState ? player.getPlayerState() : null;
  if(state === YT.PlayerState.PLAYING) player.pauseVideo();
  else player.playVideo();
}

function skip(sec){
  if(!player || !player.getCurrentTime) return;
  const now = player.getCurrentTime();
  const dur = player.getDuration ? player.getDuration() : 0;
  let next = now + sec;
  if(next < 0) next = 0;
  if(dur && next > dur) next = dur;
  player.seekTo(next, true);
}

function setVolume(v){
  if(player && player.setVolume) player.setVolume(Number(v));
}

function toggleMiniVideo(force){
  if(force === false) {
    miniVideo.classList.remove('show');
    return;
  }
  miniVideo.classList.toggle('show');
}

function showYoutubeForSelected(){
  if(selectedId) showYoutube(selectedId);
}

function showYoutube(id){
  const s = songs.find(x => x.id === id);
  if(!s) return;
  ytModalTitle.textContent = s.title;
  ytModalArtist.textContent = s.artist;
  miniVideo.classList.add('show');
  if(!player || currentSong?.id !== s.id) playSong(id);
}

function startProgress(){
  clearInterval(progressTimer);
  progressTimer = setInterval(() => {
    if(!player || !player.getCurrentTime || !player.getDuration) return;
    const c = player.getCurrentTime();
    const d = player.getDuration();
    curTime.textContent = fmt(c);
    durTime.textContent = fmt(d);
    progressFill.style.width = d ? ((c/d)*100)+'%' : '0%';
  }, 500);
}

function seekByClick(e){
  if(!player || !player.getDuration) return;
  const rect = e.currentTarget.getBoundingClientRect();
  const pct = (e.clientX - rect.left) / rect.width;
  player.seekTo(player.getDuration() * pct, true);
}

function renderRecent(){
  recentList.innerHTML = recent.map((id,i) => {
    const s = songs.find(x => x.id === id);
    if(!s) return '';
    return `<div class="recent-item"><div>♫</div><div><div class="recent-title">${i+1}. ${esc(s.title)}</div><div class="recent-artist">${esc(s.artist)}</div></div></div>`;
  }).join('') || `<div style="padding:12px;color:var(--muted);font-size:13px;">Brak ostatnio odtwarzanych.</div>`;
}

function clearRecent(){ recent=[]; saveAll(); renderRecent(); }

function openModal(){
  editingId = null;
  modalTitle.textContent = 'Dodaj utwór';
  ytUrl.value = artistInput.value = titleInput.value = bpmInput.value = keyInput.value = bandKeyInput.value = notesInput.value = '';
  refreshVocalSelects();
  vocalInput.value = vocalNames[0] || '';
  statusInput.value = 'Nowe';
  songModal.classList.add('open');
}

function closeModal(){ songModal.classList.remove('open'); }

async function analyzeLink(){
  const url = ytUrl.value.trim();
  const id = youtubeId(url);
  if(!id){ alert('Wklej poprawny link YouTube.'); return; }

  artistInput.value = artistInput.value || 'Analizuję...';
  titleInput.value = titleInput.value || 'Analizuję...';

  // 1) szybkie pobranie tytułu z noembed
  try {
    const res = await fetch(`https://noembed.com/embed?url=https://www.youtube.com/watch?v=${id}`);
    const data = await res.json();
    const parsed = parseTitle(data.title || '');
    artistInput.value = parsed.artist || '';
    titleInput.value = parsed.title || data.title || '';
  } catch {
    artistInput.value = '';
    titleInput.value = 'Utwór z YouTube';
  }

  // 2) próba automatycznego wykrycia BPM i tonacji przez Gemini
  const apiKey = localStorage.getItem('pozorantsi_gemini_key') || '';
  if(!apiKey) {
    alert('Tytuł został pobrany. Aby automatycznie wykrywać BPM i tonację, kliknij „AI BPM/tonacja” u góry i wklej klucz Gemini API.');
    return;
  }

  try {
    const prompt = `Przeanalizuj publiczny link YouTube jako utwór muzyczny. Zwróć WYŁĄCZNIE JSON bez markdown:
{
  "artist": "wykonawca",
  "title": "tytuł",
  "bpm": liczba_całkowita_lub_null,
  "key": "tonacja oryginalna np. Fm, A, C#m albo null",
  "confidence": "low/medium/high"
}
Jeżeli nie jesteś pewien BPM albo tonacji, podaj najlepsze oszacowanie i ustaw confidence na low albo medium.`;

    const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash:generateContent?key=${encodeURIComponent(apiKey)}`, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({
        contents: [{
          parts: [
            { text: prompt },
            { file_data: { file_uri: `https://www.youtube.com/watch?v=${id}` } }
          ]
        }]
      })
    });

    const json = await response.json();
    const text = json?.candidates?.[0]?.content?.parts?.map(p => p.text || '').join('') || '';
    const cleaned = text.replace(/```json|```/g,'').trim();
    const data = JSON.parse(cleaned);

    if(data.artist) artistInput.value = data.artist;
    if(data.title) titleInput.value = data.title;
    if(data.bpm) bpmInput.value = parseInt(data.bpm);
    if(data.key) keyInput.value = data.key;
    if(!bandKeyInput.value && data.key) bandKeyInput.value = data.key;

    alert('Analiza AI zakończona. Sprawdź dane i kliknij Zapisz.');
  } catch(err) {
    console.warn(err);
    alert('Nie udało się wykonać analizy AI. Dane podstawowe zostały pobrane, BPM/tonację można poprawić ręcznie.');
  }
}

function parseTitle(t){
  let clean = t.replace(/\[[^\]]*\]|\([^\)]*\)/g,'').replace(/official|video|audio|lyrics|hd|hq/gi,'').trim();
  const sep = [' - ',' – ',' — ',' | '].find(x => clean.includes(x));
  if(sep){
    const parts = clean.split(sep);
    return {artist: parts[0].trim(), title: parts.slice(1).join(sep).trim()};
  }
  return {artist:'', title:clean};
}

function openEdit(id){
  const s = songs.find(x => x.id === id);
  if(!s) return;
  editingId = id;
  modalTitle.textContent = 'Edytuj utwór';
  ytUrl.value = s.yt;
  artistInput.value = s.artist;
  titleInput.value = s.title;
  bpmInput.value = s.bpm;
  keyInput.value = s.key;
  bandKeyInput.value = s.bandKey;
  refreshVocalSelects();
  vocalInput.value = s.vocal;
  statusInput.value = s.status;
  notesInput.value = s.notes || '';
  songModal.classList.add('open');
}

function saveSong(){
  const id = youtubeId(ytUrl.value.trim());
  if(!id || !artistInput.value.trim() || !titleInput.value.trim()){
    alert('Uzupełnij link YouTube, wykonawcę i tytuł.');
    return;
  }
  const obj = {
    id: editingId || Date.now().toString(),
    artist: artistInput.value.trim(),
    title: titleInput.value.trim(),
    bpm: Number(bpmInput.value || 0),
    key: keyInput.value.trim(),
    bandKey: bandKeyInput.value.trim(),
    vocal: vocalInput.value,
    status: statusInput.value,
    date: editingId ? (songs.find(x => x.id === editingId)?.date || today()) : today(),
    yt: ytUrl.value.trim(),
    ytId: id,
    notes: notesInput.value.trim()
  };
  if(obj.vocal && !vocalNames.includes(obj.vocal)) {
    vocalNames.push(obj.vocal);
    localStorage.setItem('pozorantsi_vocalists', JSON.stringify(vocalNames));
  }
  if(editingId){
    const idx = songs.findIndex(x => x.id === editingId);
    songs[idx] = obj;
  } else {
    songs.push(obj);
    selectedId = obj.id;
  }
  closeModal();
  saveAll();
  renderSidebar();
  render();
  renderDetails();
}

function deleteSong(id){
  if(!confirm('Czy na pewno usunąć ten utwór z listy?')) return;
  songs = songs.filter(x => x.id !== id);
  selectedId = songs[0]?.id;
  saveAll();
  renderSidebar();
  render();
  renderDetails();
}

function clearFilters(){
  searchInput.value = '';
  activeLetter = '';
  activeStatus = 'Wszystkie';
  activeVocal = 'Wszyscy';
  keyFilter.value = '';
  bpmFrom.value = '';
  bpmTo.value = '';
  vocalSelect.value = '';
  statusSelect.value = '';
  dateSort.value = '';
  renderLetters();
  renderSidebar();
  render();
}

function exportData(){
  const data = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(songs, null, 2));
  const a = document.createElement('a');
  a.href = data;
  a.download = 'pozorantsi-song-base.json';
  a.click();
}

function importData(event){
  const file = event.target.files[0];
  if(!file) return;
  const r = new FileReader();
  r.onload = e => {
    try {
      const imported = JSON.parse(e.target.result);
      if(Array.isArray(imported)){
        songs = imported;
        selectedId = songs[0]?.id;
        saveAll();
        renderSidebar(); render(); renderDetails();
      }
    } catch { alert('Nieprawidłowy plik JSON.'); }
  };
  r.readAsText(file);
}

function esc(s){
  return String(s ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[m]));
}
function escAttr(s){
  return String(s ?? '').replace(/\\/g,'\\\\').replace(/'/g,"\\'").replace(/"/g,'&quot;');
}
function today(){ return new Date().toISOString().slice(0,10); }
function formatDate(d){ return d ? d.split('-').reverse().join('.') : ''; }
function fmt(t){
  t = Math.floor(t || 0);
  const m = Math.floor(t/60);
  const s = t%60;
  return m + ':' + String(s).padStart(2,'0');
}

init();
</script>
</body>
</html>
